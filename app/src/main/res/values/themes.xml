<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BugFood" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/bug_green</item>
        <item name="colorPrimaryVariant">@color/bug_green_light</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/food_orange</item>
        <item name="colorSecondaryVariant">@color/food_orange_light</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">@color/statusBarColor</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">18sp</item>
    </style>

</resources>
